{
  "name": "eco-track-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "dotenv -e .env.local -- npm run dev --prefix frontend",
    "dev:backend": "dotenv -e .env.local -- cd backend && uvicorn app.main:app --reload --port 8000",
    "build:frontend": "dotenv -e .env.local -- npm run build --prefix frontend",
    "start:frontend": "dotenv -e .env.local -- npm run start --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "test:frontend": "npm run test --prefix frontend",
    "test:backend": "dotenv -e .env.local -- cd backend && pytest"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "next": "16.2.9"
  }
}
